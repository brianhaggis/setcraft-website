# Cloudflare Pages headers — https://developers.cloudflare.com/pages/configuration/headers/

# Sensible security headers for a static brochure site.
# CSP allows 'unsafe-inline' because the page uses inline style="" attributes
# and one small inline <script> (the IntersectionObserver that pauses off-screen
# videos). It still blocks any externally-hosted script/style/frame.
/*
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: geolocation=(), microphone=(), camera=(), interest-cohort=()
  X-Robots-Tag: noindex, nofollow
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; media-src 'self'; font-src 'self'; form-action 'self' https://setcraft.lemonsqueezy.com; base-uri 'self'; frame-ancestors 'none'

# Fingerprinted, immutable assets — cache hard.
/fonts/*
  Cache-Control: public, max-age=31536000, immutable
/assets/*
  Cache-Control: public, max-age=31536000, immutable
/media/*
  Cache-Control: public, max-age=31536000, immutable

# HTML should always revalidate so copy/price edits go live immediately.
/*.html
  Cache-Control: public, max-age=0, must-revalidate
